logger -t apinfo "### executing an additional script ###"

logger -t apinfo "enabled: $_ENABLED"
logger -t apinfo "   ssid: $_SSID"
logger -t apinfo "   band: $_BAND"
logger -t apinfo "network: $_NETWORK"

EXIST=$(uci -q get network."$_NETWORK")
if [ -z "$EXIST" ]; then
  logger -t apinfo "Warning: network $_NETWORK does not exist"
fi
